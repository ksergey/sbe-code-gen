[[nodiscard]] auto {{ method_name_prefix }}() const noexcept -> {{ underlying_type }} const*
{
    return static_cast<{{ underlying_type }} const*>(buffer_ + offset_ + {{ entry.offset }});
}

[[nodiscard]] auto {{ method_name_prefix }}() noexcept -> {{ underlying_type }}*
{
    return static_cast<{{ underlying_type }}*>(buffer_ + offset_ + {{ entry.offset }});
}

[[nodiscard]] auto {{ method_name_prefix }}(std::size_t index) const -> {{ underlying_type }}
{
    if (index >= {{ type.length }}) [[unlikely]]
    {
        throw std::runtime_error("index out of range for {{ method_name_prefix }} [E104]");
    }
    return this->{{ method_name_prefix }}()[index];
}

[[nodiscard]] {{ class_name }}& {{ method_name_prefix }}(std::size_t index, {{ underlying_type }} value)
{
    if (index >= {{ type.length }}) [[unlikely]]
    {
        throw std::runtime_error("index out of range for {{ method_name_prefix }} [E104]");
    }
    this->{{ method_name_prefix }}()[index] = value;
    return *this;
}

[[nodiscard]] auto get{{ method_name_suffix }}({{ underlying_type }}* dst, std::size_t length) const -> std::size_t
{
    if (length >= {{ type.length }}) [[unlikely]]
    {
        throw std::runtime_error("length too large for get{{ method_name_suffix}} [E106]");
    }
    std::memcpy(dst, this->{{ method_name_prefix }}(), {{ type.primitive_type.size }} * length);
    return length;
}

{{ class_name }}& put{{ method_name_suffix }}({{ underlying_type }} const* src) noexcept
{
    std::memcpy(this->{{ method_name_prefix }}(), src, {{ type.primitive_type.size }} * {{ type.length }});
    return *this;
}
{% if is_string %}

[[nodiscard]] auto get{{ method_name_suffix }}AsString() const -> std::string
{
    {{ underlying_type }} const* buffer = this->{{ method_name_prefix }}();
    std::size_t length;
    for (; length < {{ type.length }} && *(buffer + length) != '\0'; ++length);
    return std::string(buffer, length);
}

[[nodiscard]] auto get{{ method_name_suffix }}AsJsonEscapedString()
{
    std::ostringstream oss;
    for (auto c: get{{ method_name_suffix }}AsStringView())
    {
        switch (c)
        {
            case '"': oss << "\\\""; break;
            case '\\': oss << "\\\\"; break;
            case '\b': oss << "\\b"; break;
            case '\f': oss << "\\f"; break;
            case '\n': oss << "\\n"; break;
            case '\r': oss << "\\r"; break;
            case '\t': oss << "\\t"; break;

            default:
                if ('\x00' <= c && c <= '\x1f')
                {
                    oss << "\\u" << std::hex << std::setw(4)
                        << std::setfill('0') << (int)(c);
                }
                else
                {
                    oss << c;
                }
        }
    }

    return oss.str();
}

[[nodiscard]] auto get{{ method_name_suffix }}AsStringView() const noexcept -> std::string_view
{
    {{ underlying_type }} const* buffer = {{ method_name_prefix }}();
    std::size_t length;
    for (; length < {{ type.length }} && *(buffer + length) != '\0'; ++length);
    return std::string_view(buffer, length);
}

{{ class_name }}& put{{ method_name_suffix }}(std::string_view str)
{
    if (str.size() > {{ type.length }})
    {
        throw std::runtime_error("length too large for put{{ method_name_suffix}} [E106]");
    }
    std::memcpy({{ method_name_prefix }}(), str.data(), str.size());
    for (std::size_t start = str.size(); start < {{ type.length }}; ++start)
    {
        {{ method_name_prefix }}()[start] = 0;
    }
    return *this;
}
{% endif %}
{% endif %}
{% endmacro %}

