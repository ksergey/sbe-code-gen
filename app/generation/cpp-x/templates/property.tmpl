{#-------------------------------------------------------------------------------------
    generate access to properties inside <message>, <composite> or <group>
  -------------------------------------------------------------------------------------#}
{% macro define(class_name, fields) %}
    {% for field in fields %}
        {{- define_property(class_name, field) }}
    {% endfor %}
{% endmacro %}

{#-------------------------------------------------------------------------------------
    generate access to property inside <message>, <composite> or <group>
  -------------------------------------------------------------------------------------#}
{% macro define_property(class_name, entry) %}
{%- if 'reference_name' in entry %}
    {% set method_name = entry.reference_name -%}
{%- else %}
    {% set method_name = entry.name -%}
{%- endif %}

{%- if entry.token == 'type' %}
    {{- define_property_type(class_name, method_name, entry) -}}
{%- elif entry.token == 'composite' %}
    {{- define_property_composite(class_name, method_name, entry) -}}
{%- elif entry.token == 'enum' %}
    {{- define_property_enum(class_name, method_name, entry) -}}
{%- elif entry.token == 'set' %}
    {{- define_property_set(class_name, method_name, entry) -}}
{%- elif entry.token == 'field' %}
    {%- if entry.type.token == 'type' %}
        {{- define_property_type(class_name, method_name, entry) -}}
    {%- elif entry.type.token == 'composite' %}
        {{- define_property_composite(class_name, method_name, entry) -}}
    {%- elif entry.type.token == 'enum' %}
        {{- define_property_enum(class_name, method_name, entry) -}}
    {%- elif entry.type.token == 'set' %}
        {{- define_property_set(class_name, method_name, entry) -}}
    {%- endif %}
{%- elif entry.token == 'group' %}
    {{- define_property_group(class_name, method_name, entry) -}}
{%- elif entry.token == 'data' %}
    {{- define_property_data(class_name, method_name, entry) -}}
{%- endif %}
{% endmacro %}

{#-------------------------------------------------------------------------------------
    xml: defined as <type> or sbe primitive type

    generate access to primitive type property
  -------------------------------------------------------------------------------------#}
{% macro define_property_type(class_name, method_name, entry) -%}
{%- if entry.token == 'field' %}
    {% set type = entry.type -%}
{%- else %}
    {% set type = entry -%}
{%- endif %}

{%- if type.length == 1 %}
    {{- define_property_type_single(class_name, method_name, entry) }}
{%- elif type.length > 1 %}
    {{- define_property_type_array(class_name, method_name, entry) }}
{%- endif %}
{%- endmacro %}

{#-------------------------------------------------------------------------------------
    xml: defined as <type> or sbe primitive type of length 1
  -------------------------------------------------------------------------------------#}
{% macro define_property_type_single(class_name, method_name, entry) %}
{%- if entry.token == 'field' %}
    {% set type = entry.type -%}
{%- else %}
    {% set type = entry -%}
{%- endif %}
{%- set underlying_type = type.primitive_type.name | replace_keyword -%}
{%- set method_name_prefix = method_name | format_method_name_prefix -%}

[[nodiscard]] static constexpr auto {{ method_name_prefix }}Id() noexcept -> std::uint16_t
{
    return std::uint16_t({{ entry.id or -1 }});
}

[[nodiscard]] static constexpr auto {{ method_name_prefix }}SinceVersion() noexcept -> std::uint16_t
{
    return {{ type.since_version }};
}

[[nodiscard]] auto {{ method_name_prefix }}InActingVersion() const noexcept -> bool
{
    return actingVersion_ >= {{ method_name_prefix }}SinceVersion();
}
{% if entry.presence != 'constant' %}

[[nodiscard]] auto {{ method_name_prefix }}EncodingOffset() noexcept -> std::size_t
{
    return {{ entry.offset }};
}
{% endif %}

[[nodiscard]] auto {{ method_name_prefix }}NullValue() noexcept -> {{ underlying_type }}
{
    return {{ type.null_value | replace_keyword }};
}

[[nodiscard]] auto {{ method_name_prefix }}MinValue() noexcept -> {{ underlying_type }}
{
    return {{ type.min_value | replace_keyword }};
}

[[nodiscard]] auto {{ method_name_prefix }}MaxValue() noexcept -> {{ underlying_type }}
{
    return {{ type.max_value | replace_keyword }};
}

[[nodiscard]] static constexpr auto {{ method_name_prefix }}EncodingLength() noexcept -> std::size_t
{
    return {{ type.encoded_length }};
}
{% if entry.presence == 'constant' %}

[[nodiscard]] static constexpr auto {{ method_name_prefix }}() noexcept -> {{ underlying_type }}
{
    {% if type.primitive_type.name == 'char' %}
    return '{{ type.const_value }}';
    {% else %}
    return {{ type.const_value }};
    {% endif %}
}
{% endif %}
{% if entry.presence == 'required' or entry.presence == 'optional' %}

[[nodiscard]] auto {{ method_name_prefix }}() const noexcept -> {{ underlying_type }}
{
    {{ underlying_type }} val;
    std::memcpy(&val, buffer_ + offset_ + {{ entry.offset }}, sizeof(val));
    return val; // TODO: little endian decode
}

{{ class_name }}& {{ method_name_prefix }}({{ underlying_type }} value) noexcept
{
    // TODO: little endian encode
    std::memcpy(buffer_ + offset_ + {{ entry.offset }}, &value, sizeof(value));
    return *this;
}
{% endif %}
{% endmacro %}

