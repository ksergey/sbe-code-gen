{% set messageHeader = schema.header_type %}
{% set blockLength = (messageHeader.contained_types | selectattr('name', 'equalto', 'blockLength') | first ) %}
{% set templateId = (messageHeader.contained_types | selectattr('name', 'equalto', 'templateId') | first ) %}
{% set schemaId = (messageHeader.contained_types | selectattr('name', 'equalto', 'schemaId') | first ) %}
{% set version = (messageHeader.contained_types | selectattr('name', 'equalto', 'version') | first ) %}

{% set version_cpp_t = version.primitive_type.name | replace_keyword %}

{# ------------------------------------ #}

{% macro enum(type) %}
{% set class_cpp_t = type.name | fmt_class_name %}
{% set enc_cpp_t = type.encoding_type.name | replace_keyword %}
// name:            {{ type.name }}
// description:     {{ type.description }}
// since version:   {{ type.since_version }}
// deprecated:      {{ type.deprecated }}
// encoded length:  {{ type.encoded_length }}
enum class {{ class_cpp_t }} : {{ enc_cpp_t }} {
{% for entry in type.valid_values %}
    {% if type.encoding_type.name == 'char' %}
    {{ entry.name }} = '{{ entry.value }}',
    {% else %}
    {{ entry.name }} = {{ entry.value }},
    {% endif %}
{% endfor %}
    SBE_NULL = {{ type.null_value | replace_keyword }},
};

static_assert(sizeof({{ class_cpp_t }}) == {{ type.encoded_length }});
{%- endmacro %}

{# ------------------------------------ #}

{% macro set(type) %}
{% set class_cpp_t = type.name | fmt_class_name %}
{% set enc_cpp_t = type.encoding_type.name | replace_keyword %}
// name:            {{ type.name }}
// description:     {{ type.description }}
// since version:   {{ type.since_version }}
// deprecated:      {{ type.deprecated }}
// encoded length:  {{ type.encoded_length }}
class {{ class_cpp_t }} final {
private:
    {{ enc_cpp_t }} value_ = 0;

public:
{% for choice in type.choices %}
    static constexpr auto k{{ choice.name | upper_first }}Bit = {{ enc_cpp_t }}(1 << {{ choice.value }}u);
{% endfor %}

    constexpr {{ class_cpp_t }}() = default;

    constexpr {{ class_cpp_t }}({{ enc_cpp_t }} value) noexcept
        : value_{value}
    {}

    [[nodiscard]] constexpr auto rawValue() const noexcept -> {{ enc_cpp_t }} {
        return value_;
    }

    constexpr void setRawValue({{ enc_cpp_t }} value) noexcept {
        value_ = value;
    }

    constexpr {{ class_cpp_t }}& reset() noexcept {
        value_ = 0;
        return *this;
    }
{% for choice in type.choices %}
    {% set choice_bit = 'k' ~ choice.name | upper_first ~ 'Bit' %}

    [[nodiscard]] constexpr auto {{ choice.name | lower_first }}() noexcept -> bool {
        return {{ choice_bit }} == ({{ choice_bit }} & value_);
    }

    constexpr {{ class_cpp_t }}& {{ choice.name | lower_first }}(bool value) noexcept {
        value_ = value
            ? (value_ | {{ choice_bit }})
            : (value_ & ~{{ choice_bit }})
        ;
        return *this;
    }
{% endfor %}
};

static_assert(sizeof({{ class_cpp_t }}) == {{ type.encoded_length }});
{%- endmacro %}

{# ------------------------------------ #}

{% macro composite(type) %}
// composite definition here
{%- endmacro %}

